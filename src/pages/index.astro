---
import business from "../config/business.json";
import services from "../config/services.json";
import content from "../config/content.json";
import "../styles/global.css";

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={business.seoDescription} />
    <meta name="theme-color" content={business.primaryColor} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{business.seoTitle}</title>
  </head>
  <body style={`--brand:${business.primaryColor};--accent:${business.accentColor};`}>
    <div class="notice">{business.conceptNotice}</div>
    <div class="topbar">
      <div class="container">
        <span>{business.hours[0]}</span>
        <span>{business.phoneDisplay}</span>
      </div>
    </div>
    <header>
      <nav class="container" aria-label="Main navigation">
        <a class="logo" href="#top">{business.shortName}</a>
        <div class="navlinks">
          <a href="#specialities">Specialities</a>
          <a href="#doctors">Doctors</a>
          <a href="#services">Treatments</a>
          <a href="#reviews">Testimonials</a>
          <a href="#contact">Contact</a>
        </div>
        <a class="button accent" href="#appointment">Get appointment</a>
      </nav>
    </header>

    <main id="top">
      <section class="hero">
        <div class="container hero-inner">
          <div class="hero-copy">
            <div class="eyebrow">Family dental care in Baner, Pune</div>
            <h1>{business.tagline}</h1>
            <p>{business.description}</p>
            <ul class="trust-list hero-trust">
              {content.trustPoints.map((point) => <li>{point}</li>)}
            </ul>
            <div class="hero-actions">
              <a class="button accent" href="#appointment">Book an appointment</a>
              <a class="button secondary" href={business.whatsappLink}>Chat on WhatsApp</a>
            </div>
          </div>
        </div>
      </section>

      <section class="section doctors-section" id="doctors">
        <div class="container">
          <div class="center-title">
            <div class="eyebrow">Our doctors</div>
            <h2>Orthodontic doctor profile</h2>
            <p class="muted">For now, this demo shows one fictional orthodontic doctor profile with clear appointment action.</p>
          </div>
          <div class="doctor-grid">
            {content.doctors.map((doctor, index) => (
              <article class="doctor-card">
                <div class={`doctor-photo doctor-photo-${index + 1}`}></div>
                <div class="doctor-body">
                  <h3>{doctor.name}</h3>
                  <p class="doctor-role">{doctor.role}</p>
                  <ul>
                    <li>{doctor.speciality}</li>
                    <li>{doctor.experience}</li>
                    <li>{doctor.location}</li>
                  </ul>
                  <small>{doctor.note}</small>
                  <a class="mini-button" href="#appointment">Book appointment</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="quick-actions" aria-label="Quick actions">
        <div class="container quick-grid">
          {content.quickActions.map((action) => (
            <a class="quick-card" href={action.href}>
              <span class="quick-dot"></span>
              <strong>{action.title}</strong>
              <small>{action.text}</small>
              <em>{action.cta} -></em>
            </a>
          ))}
        </div>
      </section>

      <section class="section compact" id="specialities">
        <div class="container">
          <div class="center-title">
            <div class="eyebrow">Our specialities</div>
            <h2>Easy-to-scan treatment categories</h2>
          </div>
          <div class="speciality-grid">
            {content.specialities.map((item) => (
              <article class="speciality-card">
                <span>{item.name.slice(0, 2).toUpperCase()}</span>
                <h3>{item.name}</h3>
                <p>{item.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section" id="services">
        <div class="container">
          <div class="section-title">
            <div class="eyebrow">Treatments</div>
            <h2>Care built around clear choices</h2>
            <p class="muted">Every treatment starts with a conversation, an assessment and a clear explanation of suitable options.</p>
          </div>
          <div class="services-grid">
            {services.map((service) => (
              <article class="service">
                <div class="service-number">{service.number}</div>
                <h3>{service.name}</h3>
                <p class="muted">{service.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section banner-section">
        <div class="container">
          <div class="screening-banner">
            <div>
              <div class="eyebrow">Oral health screening</div>
              <h2>{content.screening.heading}</h2>
              <p>{content.screening.text}</p>
              <a class="button accent" href="#appointment">{content.screening.cta}</a>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="about">
        <div class="container about-grid">
          <div class="about-visual" role="img" aria-label="A welcoming dental clinic reception and consultation area"></div>
          <div>
            <div class="eyebrow">About {business.shortName}</div>
            <h2>{content.about.heading}</h2>
            <p>{content.about.body}</p>
            <p>{content.about.bodyTwo}</p>
            <div class="stats-grid">
              {content.stats.map((stat) => (
                <div class="stat-card">
                  <strong>{stat.value}</strong>
                  <span>{stat.label}</span>
                </div>
              ))}
            </div>
            <ul class="payment-list">
              {content.payments.map((payment) => <li>{payment}</li>)}
            </ul>
          </div>
        </div>
      </section>

      <section class="section reviews" id="reviews">
        <div class="container">
          <div class="center-title light">
            <div class="eyebrow">Illustrative testimonials</div>
            <h2>Our patients speak</h2>
          </div>
          <div class="reviews-grid">
            {content.reviews.map((review) => (
              <article class="review">
                <p>"{review.quote}"</p>
                <strong>{review.author}</strong>
                <span>{review.source}</span>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section resources-section">
        <div class="container">
          <div class="center-title">
            <div class="eyebrow">Oral health resources</div>
            <h2>Useful reading before booking</h2>
          </div>
          <div class="resource-grid">
            {content.resources.map((resource) => (
              <article class="resource-card">
                <div class="resource-image"></div>
                <h3>{resource.title}</h3>
                <p>{resource.text}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section" id="faq">
        <div class="container">
          <div class="section-title">
            <div class="eyebrow">Frequently asked questions</div>
            <h2>Useful answers before you visit</h2>
          </div>
          <div class="faq-list">
            {content.faqs.map((faq) => (
              <details>
                <summary>{faq.question}</summary>
                <p>{faq.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>

      <section class="section" id="appointment">
        <div class="container contact-grid">
          <div>
            <div class="eyebrow">Request an appointment</div>
            <h2>Choose your preferred date and time</h2>
            <p class="muted">This safe demo form validates your entry locally, displays a confirmation and does not transmit or store personal data.</p>
            <form id="demo-form">
              <div class="field">
                <label for="name">Name</label>
                <input id="name" name="name" autocomplete="name" required />
              </div>
              <div class="field">
                <label for="phone">Mobile number</label>
                <input id="phone" name="phone" type="tel" inputmode="tel" pattern="[0-9+\s-]{10,16}" required />
              </div>
              <div class="field">
                <label for="concern">What would you like help with?</label>
                <select id="concern" name="concern" required>
                  <option value="">Choose an option</option>
                  {services.map((service) => <option value={service.name}>{service.name}</option>)}
                </select>
              </div>
              <div class="form-row">
                <div class="field">
                  <label for="date">Preferred date</label>
                  <input id="date" name="date" type="date" required />
                </div>
                <div class="field">
                  <label for="time">Preferred time</label>
                  <select id="time" name="time" required>
                    <option value="">Choose time</option>
                    <option value="09:00 AM">09:00 AM</option>
                    <option value="10:00 AM">10:00 AM</option>
                    <option value="11:00 AM">11:00 AM</option>
                    <option value="12:00 PM">12:00 PM</option>
                    <option value="01:00 PM">01:00 PM</option>
                    <option value="02:00 PM">02:00 PM</option>
                    <option value="03:00 PM">03:00 PM</option>
                    <option value="04:00 PM">04:00 PM</option>
                    <option value="05:00 PM">05:00 PM</option>
                    <option value="06:00 PM">06:00 PM</option>
                    <option value="07:00 PM">07:00 PM</option>
                    <option value="08:00 PM">08:00 PM</option>
                  </select>
                </div>
              </div>
              <div class="field">
                <label for="message">Optional note</label>
                <textarea id="message" name="message"></textarea>
              </div>
              <button class="button accent" type="submit">Send demo request</button>
              <div class="form-status" id="form-status" aria-live="polite"></div>
            </form>
          </div>
          <aside class="contact-card" id="contact">
            <div class="eyebrow">Visit or contact</div>
            <h2>{business.name}</h2>
            <p>{business.address}</p>
            {business.hours.map((line) => <p><strong>{line}</strong></p>)}
            <p><a href={`tel:${business.phoneLink}`}>{business.phoneDisplay}</a></p>
            <p><a href={business.whatsappLink}>Message on WhatsApp</a></p>
            <p><a href={business.mapLink}>Open map</a></p>
          </aside>
        </div>
      </section>
    </main>

    <footer>
      <div class="container footer-grid">
        <div>
          <h3>{business.name}</h3>
          <p>{business.conceptNotice}</p>
        </div>
        <div>
          <strong>Explore</strong>
          <a href="#specialities">Specialities</a>
          <a href="#doctors">Doctors</a>
          <a href="#services">Treatments</a>
          <a href="#faq">FAQs</a>
        </div>
        <div>
          <strong>Contact</strong>
          <a href={`tel:${business.phoneLink}`}>{business.phoneDisplay}</a>
          <a href={business.whatsappLink}>WhatsApp</a>
          <a href={business.mapLink}>Map</a>
        </div>
      </div>
      <div class="container"><small>&copy; {year} Fictional concept demo. No medical advice or services are provided.</small></div>
    </footer>

    <div class="mobile-actions" aria-label="Quick contact actions">
      <a class="button secondary" href={`tel:${business.phoneLink}`}>Call clinic</a>
      <a class="button accent" href="#appointment">Book visit</a>
    </div>

    <script>
      const form = document.querySelector<HTMLFormElement>("#demo-form");
      const status = document.querySelector<HTMLElement>("#form-status");
      const date = document.querySelector<HTMLInputElement>("#date");
      if (date) date.min = new Date().toISOString().slice(0, 10);
      form?.addEventListener("submit", (event) => {
        event.preventDefault();
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }
        const formData = new FormData(form);
        const chosenDate = formData.get("date");
        const chosenTime = formData.get("time");
        if (status) status.textContent = `Demo confirmed for ${chosenDate} at ${chosenTime}. No information was sent or stored.`;
        form.reset();
      });
    </script>
  </body>
</html>
